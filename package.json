{
  "name": "tes-mcp-server-sendiri",
  "version": "1.0.0",
  "description": "MCP server menggunakan mysql untuk melihat data",
  "license": "ISC",
  "author": "Awanda",
  "main": "main.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.awanda.aiagent",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/",
        "to": "build/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.9",
    "marked": "^17.0.4",
    "mysql": "^2.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mysql": "^2.15.27",
    "@types/node": "^25.3.3",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3"
  }
}
